{
  "persistence_enabled": false,
  "app_name": "Interactive Historical Timeline",
  "avoids_viewport_units": true,
  "avoids_browser_dialogs": true,
  "verified_editable_features_usage": true,
  "edit_panel": {
    "title_label": {
      "type": "label",
      "text": "Timeline Settings",
      "size": "large"
    },
    "timeline_title": {
      "type": "text_input",
      "label": "Timeline Title",
      "placeholder": "Enter timeline title"
    },
    "subtitle_text": {
      "type": "text_input",
      "label": "Subtitle",
      "placeholder": "Enter subtitle"
    }
  }
}

      .event-content:nth-child(odd) .event-date,
      .event-content:nth-child(even) .event-date {
        order: 1;
        margin-bottom: 0.5rem;
      }

      .event-content:nth-child(odd) .event-card,
      .event-content:nth-child(even) .event-card {
        order: 3;
      }

      .dot {
        position: absolute;
        left: 8px;
        top: 8px;
      }

      .timeline-title {
        font-size: 1.8rem;
      }

      .timeline-subtitle {
        font-size: 0.9rem;
      }
    }
  </style>
  <style>body { box-sizing: border-box; }</style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
 </head>
 <body>
  <div class="timeline-wrapper">
   <div class="timeline-header">
    <h1 class="timeline-title" id="mainTitle">Civilizações Antigas</h1>
    <p class="timeline-subtitle" id="mainSubtitle">3000 a.C. - 500 d.C. | Egípcios, Gregos e Romanos</p>
   </div>
   <div class="timeline-container">
    <div class="timeline-line" id="timelineEvents"></div>
   </div>
  </div>
  <script>
    const defaultConfig = {
      timeline_title: "Civilizações Antigas",
      subtitle_text: "3000 a.C. - 500 d.C. | Egípcios, Gregos e Romanos"
    };

    let config = { ...defaultConfig };

    const timelineData = [
      {
        id: 1,
        year: "3100 a.C.",
        title: "Unificação do Egito",
        description: "O Faraó Narmer unifica o Alto e Baixo Egito, marcando o início da civilização egípcia dinástica.",
        culture: "egyptian",
        icon: "pyramid"
      },
      {
        id: 2,
        year: "2589 a.C.",
        title: "Grande Pirâmide de Giza",
        description: "Construção da Grande Pirâmide do Faraó Quéops, uma das Sete Maravilhas do Mundo Antigo.",
        culture: "egyptian",
        icon: "landmark"
      },
      {
        id: 3,
        year: "1550 a.C.",
        title: "Império Novo Egípcio",
        description: "Período de ouro do Egito com o Faraó Ahmose fundando a 18ª dinastia e expandindo o império.",
        culture: "egyptian",
        icon: "crown"
      },
      {
        id: 4,
        year: "776 a.C.",
        title: "Primeiros Jogos Olímpicos",
        description: "Primeiras Olimpíadas Antigas são realizadas em Olímpia, Grécia, celebrando os deuses.",
        culture: "greek",
        icon: "medal"
      },
      {
        id: 5,
        year: "461 a.C.",
        title: "Era de Péricles",
        description: "Período dourado de Atenas com o desenvolvimento da democracia grega e construção do Partenão.",
        culture: "greek",
        icon: "building"
      },
      {
        id: 6,
        year: "431 a.C.",
        title: "Guerra do Peloponeso",
        description: "Conflito entre Atenas e Esparta que mudou o rumo da Grécia Antiga.",
        culture: "greek",
        icon: "swords"
      },
      {
        id: 7,
        year: "146 a.C.",
        title: "Domínio Romano sobre Grécia",
        description: "Roma conquista a Grécia e a incorpora ao seu império, absorvendo sua cultura.",
        culture: "roman",
        icon: "sword"
      },
      {
        id: 8,
        year: "27 a.C.",
        title: "Império Romano",
        description: "Otaviano se torna Augusto, primeiro imperador de Roma, iniciando a Pax Romana.",
        culture: "roman",
        icon: "crown"
      },
      {
        id: 9,
        year: "79 d.C.",
        title: "Erupção do Vesúvio",
        description: "Vulcão Vesúvio irrompe, destruindo Pompeia e Herculano, preservando vidas e cultura romana.",
        culture: "roman",
        icon: "zap"
      },
      {
        id: 10,
        year: "476 d.C.",
        title: "Queda do Império Romano",
        description: "Rômulo Augústulo deposto marca o fim oficial do Império Romano do Ocidente.",
        culture: "roman",
        icon: "x"
      }
    ];

    // Renderizar eventos da timeline
    function renderTimeline() {
      const container = document.getElementById('timelineEvents');
      container.innerHTML = timelineData.map((event, index) => `
        <div class="event-content" data-event-id="${event.id}">
          <div class="event-date">${event.year}</div>
          <div class="event-dot">
            <div class="dot"></div>
          </div>
          <div class="event-card" data-expanded="false">
            <div class="event-year">${event.year}</div>
            <div class="event-title">
              <i data-lucide="${event.icon}" class="event-icon"></i>
              ${event.title}
            </div>
            <div class="event-description">${event.description}</div>
            <div class="event-culture ${event.culture}">${event.culture.charAt(0).toUpperCase() + event.culture.slice(1)}</div>
          </div>
        </div>
      `).join('');

      // Adicionar event listeners aos cartões
      document.querySelectorAll('.event-card').forEach(card => {
        card.addEventListener('click', function() {
          const isExpanded = this.dataset.expanded === 'true';
          this.dataset.expanded = !isExpanded;
          this.classList.toggle('expanded');
        });
      });

      lucide.createIcons();
    }

    // Inicializar Element SDK
    window.elementSdk.init({
      defaultConfig,
      onConfigChange: async (newConfig) => {
        config = newConfig;
        document.getElementById('mainTitle').textContent = config.timeline_title || defaultConfig.timeline_title;
        document.getElementById('mainSubtitle').textContent = config.subtitle_text || defaultConfig.subtitle_text;
      },
      mapToCapabilities: () => ({
        recolorables: [],
        borderables: [],
        fontEditable: undefined,
        fontSizeable: undefined
      }),
      mapToEditPanelValues: () => new Map([
        ['timeline_title', config.timeline_title || defaultConfig.timeline_title],
        ['subtitle_text', config.subtitle_text || defaultConfig.subtitle_text]
      ])
    });

    // Renderizar timeline
    renderTimeline();
  </script>
 <script>(function(){function c(){var b=a.contentDocument||a.contentWindow.document;if(b){var d=b.createElement('script');d.innerHTML="window.__CF$cv$params={r:'9e89ad567172031f',t:'MTc3NTU3MTY2OS4wMDAwMDA='};var a=document.createElement('script');a.nonce='';a.src='/cdn-cgi/challenge-platform/scripts/jsd/main.js';document.getElementsByTagName('head')[0].appendChild(a);";b.getElementsByTagName('head')[0].appendChild(d)}}if(document.body){var a=document.createElement('iframe');a.height=1;a.width=1;a.style.position='absolute';a.style.top=0;a.style.left=0;a.style.border='none';a.style.visibility='hidden';document.body.appendChild(a);if('loading'!==document.readyState)c();else if(window.addEventListener)document.addEventListener('DOMContentLoaded',c);else{var e=document.onreadystatechange||function(){};document.onreadystatechange=function(b){e(b);'loading'!==document.readyState&&(document.onreadystatechange=e,c())}}}})();</script></body>
</html>